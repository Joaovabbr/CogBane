  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BossDialogue
  dialogosIntro:
  - GGGRRRRRR!!
  - "Mas que merda... o que diabos aconteceu com voc\xEA?"
  - UGRHHAAAAAAAAAAAAAHH!
  - "Bom, voc\xEA n\xE3o me deu outra escolha."
  retratosIntro:
  - {fileID: -8622016061093834062, guid: 6ad86a3a1ab9bd8049890a692832d32a, type: 3}
  - {fileID: 1832072279166882629, guid: 74491871f67c3848fb4aef4c4d0db04e, type: 3}
  - {fileID: -8622016061093834062, guid: 6ad86a3a1ab9bd8049890a692832d32a, type: 3}
  - {fileID: 1832072279166882629, guid: 74491871f67c3848fb4aef4c4d0db04e, type: 3}
  nomesIntro:
  - Black Chuck
  - Damon Graves
  - Black Chuck
  - Damon Graves
  dialogosDerrota:
  - UUUUGGGHHHH
  - "Malditos sejam os humanos... voc\xEAs s\xF3  destroem nossas florestas, nossos
    lares...   "
  - "Eu amaldi\xE7oo todos voc\xEAs, principalmente esser verme do Mr. M."
  - Mr. M...? Vi esse nome no jornal de hoje.
  - "Acho que terei que fazer uma visita na cidade... ugh, esse dia fica cada vez
    mais cansativo.\t"
  retratosDerrota:
  - {fileID: -8622016061093834062, guid: 6ad86a3a1ab9bd8049890a692832d32a, type: 3}
